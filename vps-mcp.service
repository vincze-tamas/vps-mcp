[Unit]
Description=VPS MCP Server
After=network.target

[Service]
Type=simple
User=poke
Group=poke
WorkingDirectory=/home/poke/vps-mcp
EnvironmentFile=/home/poke/vps-mcp/.env
ExecStart=/home/poke/vps-mcp/venv/bin/python /home/poke/vps-mcp/vps_mcp.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
